generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id            String   @id
  name          String
  role          String
  context       String
  status        String   @default("idle")
  systemPrompt  String
  modelProvider String   @default("openai")
  modelName     String   @default("gpt-4o-mini")
  temperature   Float    @default(0.3)
  maxTokens     Int      @default(4096)
  startedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  episodicEvents EpisodicEvent[]
  auditTrail     AuditTrail[]
  tasks          Task[]
}

model EpisodicEvent {
  id        String   @id @default(uuid())
  agentId   String
  type      String
  data      Json
  timestamp DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])
  @@index([agentId, timestamp])
  @@index([type])
}

model AuditTrail {
  id        String   @id @default(uuid())
  agentId   String
  action    String
  input     Json?
  output    Json?
  error     String?
  duration  Int      @default(0)
  timestamp DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])
  @@index([agentId, timestamp])
}

model Task {
  id         String   @id @default(uuid())
  agentId    String
  type       String
  input      Json
  output     Json?
  status     String   @default("pending")
  priority   Int      @default(0)
  retries    Int      @default(0)
  maxRetries Int      @default(3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
  @@index([agentId, status])
  @@index([status])
}

model Workflow {
  id        String   @id
  name      String
  steps     Json
  status    String   @default("running")
  onError   String   @default("stop")
  maxRetries Int     @default(3)
  startedAt DateTime @default(now())
  completedAt DateTime?

  executions WorkflowExecution[]
}

model WorkflowExecution {
  id         String   @id @default(uuid())
  workflowId String
  stepId     String
  agentId    String
  status     String   @default("pending")
  input      Json
  output     Json?
  error      String?
  startedAt  DateTime?
  completedAt DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id])
  @@index([workflowId])
}

model Product {
  id          String   @id
  sku         String   @unique
  name        String
  description String?
  category    String
  status      String   @default("draft")
  revision    String   @default("1.0")
  cadFileHash String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bom        BOM?
  revisions  Revision[]
  components Component[]
  @@index([sku])
  @@index([status])
  @@index([category])
}

model BOM {
  id           String @id
  productId    String @unique
  revision     String @default("1.0")
  components   Json
  validated    Boolean @default(false)
  validatedAt  DateTime?
  validatedBy  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Component {
  id          String   @id
  productId   String
  name        String
  quantity    Int
  materialSpec String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
}

model Revision {
  id              String   @id
  productId       String
  revisionNumber  String
  changes         String?
  approvedBy      String?
  approvedAt      DateTime?
  cadFileHash     String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId])
  @@index([status])
}

model StockItem {
  id           String   @id
  sku          String
  warehouseId  String
  quantity     Int      @default(0)
  reorderPoint Int      @default(10)
  reservedQty  Int      @default(0)
  unit         String   @default("units")
  updatedAt    DateTime @updatedAt

  @@unique([sku, warehouseId])
  @@index([sku])
  @@index([warehouseId])
}

model Warehouse {
  id      String @id
  name    String
  city    String
  state   String
  active  Boolean @default(true)

  @@index([active])
}

model StockMovement {
  id          String   @id @default(uuid())
  sku         String
  warehouseId String
  type        String
  quantity    Int
  referenceId String?
  reason      String?
  timestamp   DateTime @default(now())

  @@index([sku, warehouseId])
  @@index([type])
  @@index([timestamp])
}

model Order {
  id            String   @id
  customerId    String
  channel       String   @default("manual")
  status        String   @default("draft")
  subtotal      Float    @default(0)
  shippingCost  Float    @default(0)
  discount      Float    @default(0)
  grandTotal    Float    @default(0)
  currency      String   @default("BRL")
  shippingAddress Json?
  correlationId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines       OrderLine[]
  fulfillment Fulfillment?
  returns     Return[]
  @@index([customerId])
  @@index([status])
  @@index([channel])
}

model OrderLine {
  id        String @id @default(uuid())
  orderId   String
  sku       String
  name      String
  quantity  Int    @default(1)
  unitPrice Float  @default(0)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([orderId])
}

model Fulfillment {
  id              String   @id
  orderId         String   @unique
  type            String   @default("warehouse")
  centerId        String?
  status          String   @default("pending")
  estimatedDays   Int      @default(3)
  trackingCode    String?
  carrierId       String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([status])
}

model Return {
  id        String   @id
  orderId   String
  reason    String
  items     Json
  status    String   @default("requested")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([status])
}

model Customer {
  id            String   @id
  name          String
  email         String   @unique
  phone         String?
  document      String?
  tier          String   @default("bronze")
  loyaltyPoints Int      @default(0)
  rfmScore      Json?
  tags          String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tier])
}

model Shipment {
  id            String   @id
  orderId       String   @unique
  carrierId     String
  trackingCode  String
  cost          Float    @default(0)
  estimatedDays Int      @default(3)
  status        String   @default("created")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model PriceListItem {
  id        String   @id
  productId String   @unique
  price     Float    @default(0)
  cost      Float?
  currency  String   @default("BRL")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCard {
  id             String   @id
  productId      String   @unique
  name           String
  categoryId     String
  status         String   @default("draft")
  description    String?
  images         String[] @default([])
  videos         String[] @default([])
  attributes     Json     @default("{}")
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[] @default([])
  variants       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

model Mold {
  id          String   @id
  moldCode    String   @unique
  productId   String
  status      String   @default("design")
  cavities    Int      @default(1)
  steelType   String
  cycleLife   Int
  coolingConfig String?
  ejectorType  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([productId])
}

model MaintenanceRecord {
  id          String   @id
  moldId      String
  type        String
  description String
  cost        Float    @default(0)
  performedAt DateTime
  createdAt   DateTime @default(now())
}

model CNCJob {
  id             String   @id
  partNumber     String
  estimatedHours Float    @default(0)
  priority       Int      @default(1)
  status         String   @default("scheduled")
  machineId      String?
  programId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model ProductionRun {
  id               String   @id
  moldId           String
  machineId        String
  productSku       String
  status           String   @default("scheduled")
  targetQuantity   Int      @default(0)
  producedQuantity Int      @default(0)
  scrapQuantity    Int      @default(0)
  defectRate       Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([moldId])
}

model QualityCheck {
  id         String   @id
  runId      String
  passed     Boolean  @default(false)
  defects    String[] @default([])
  parameters Json
  createdAt  DateTime @default(now())
}

model PlastisolFormulation {
  id          String   @id
  formulaCode String   @unique
  components  Json
  viscosity   Float    @default(0)
  gelTemperature Float  @default(0)
  curingProfile   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CuringCycle {
  id               String   @id
  formulationId    String
  lineId           String
  status           String   @default("started")
  targetTemperature Float  @default(0)
  targetDuration   Int      @default(0)
  actualTemperature Float?
  actualDuration   Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ChannelListing {
  id         String   @id
  productId  String
  channel    String
  price      Float    @default(0)
  stock      Int      @default(0)
  status     String   @default("draft")
  channelSku String?
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, channel])
  @@index([channel])
}

model SaleTransaction {
  id            String   @id
  storeId       String
  items         Json
  totalAmount   Float    @default(0)
  paymentMethod String
  createdAt     DateTime @default(now())
}

model Store {
  id        String   @id
  name      String
  city      String
  state     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ChatOrder {
  id             String   @id
  telegramUserId String
  items          Json
  totalAmount    Float    @default(0)
  status         String   @default("browsing")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ChatSession {
  id             String   @id
  telegramUserId String   @unique
  username       String
  state          Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Report {
  id        String   @id
  name      String
  type      String
  period    String
  status    String   @default("generating")
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Metric {
  id        String   @id
  name      String   @unique
  value     Float    @default(0)
  unit      String
  updatedAt DateTime @updatedAt
}

model Insight {
  id          String   @id
  title       String
  description String
  context     String
  severity    String   @default("info")
  createdAt   DateTime @default(now())
}

model User {
  id           String     @id
  email        String     @unique
  passwordHash String
  name         String
  active       Boolean    @default(true)
  refreshToken String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles UserRole[]

  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// === CNC Machining extras ===

model CNCTool {
  id                 String  @id
  toolNumber         Int
  machineId          String
  name               String?
  wearMicrons        Float   @default(0)
  thresholdMicrons   Float
  cyclesCompleted    Int     @default(0)
  estimatedCyclesRemaining Int @default(0)
  status             String  @default("active")
  lastReplacedAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([machineId, status])
  @@index([status])
}

model MachineDowntime {
  id              String   @id
  machineId       String
  reason          String
  detail          String?
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?
  reportedBy      String?
  resolvedBy      String?

  @@index([machineId])
  @@index([reason])
}

// === Injection Molding extras ===

model DefectRecord {
  id          String   @id
  runId       String
  batchId     String?
  defectType  String
  quantity    Int
  severity    String   @default("cosmetic")
  possibleCause String?
  detectedAt  DateTime
  detectedBy  String?

  @@index([runId])
  @@index([defectType])
  @@index([detectedAt])
}

// === Marketplace extras ===

model CompetitorPrice {
  id            String   @id
  sku           String
  channel       String
  competitorId  String
  competitorName String?
  ourPrice      Float    @default(0)
  theirPrice    Float    @default(0)
  detectedAt    DateTime
  createdAt     DateTime @default(now())

  @@unique([sku, channel, competitorId])
  @@index([sku])
  @@index([channel])
}

model ChannelAccountHealth {
  id               String   @id
  channel          String
  accountId        String
  reputationLevel  String?
  reputationColor  String?
  cancellationRate Float    @default(0)
  delayRate        Float    @default(0)
  healthScore      Int      @default(100)
  warnings         String[] @default([])
  checkedAt        DateTime
  createdAt        DateTime @default(now())
}

// === Retail extras ===

model RegisterSession {
  id              String   @id
  storeId         String
  registerId      String
  operatorId      String?
  openingBalance  Float    @default(0)
  closingBalance  Float    @default(0)
  totalSales      Float    @default(0)
  saleCount       Int      @default(0)
  cashDifference  Float    @default(0)
  openedAt        DateTime
  closedAt        DateTime?
  openedBy        String?
  closedBy        String?

  @@index([storeId])
  @@index([registerId])
}

// === Order Management extras ===

model Invoice {
  id          String   @id
  orderId     String   @unique
  number      String   @unique
  accessKey   String?
  xmlUrl      String?
  danfeUrl    String?
  amount      Float    @default(0)
  generatedAt DateTime
  createdAt   DateTime @default(now())
}

model Payment {
  id            String   @id
  orderId       String
  amount        Float    @default(0)
  method        String
  installment   Int      @default(1)
  transactionId String?
  status        String   @default("pending")
  receivedAt    DateTime
  createdAt     DateTime @default(now())

  @@index([orderId])
  @@index([status])
}

// === Customer extras ===

model CustomerSegment {
  id          String   @id
  customerId  String
  segment     String
  recency     Int      @default(0)
  frequency   Int      @default(0)
  monetary    Float    @default(0)
  totalScore  Int      @default(0)
  segmentedAt DateTime
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([segment])
}

model LoyaltyReward {
  id          String   @id
  customerId  String
  rewardType  String
  pointsCost  Int      @default(0)
  rewardValue Float    @default(0)
  claimedAt   DateTime
  createdAt   DateTime @default(now())

  @@index([customerId])
}

model CustomerInteraction {
  id          String   @id
  customerId  String
  type        String
  channel     String?
  summary     String?
  sentiment   String   @default("neutral")
  recordedAt  DateTime
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([type])
  @@index([sentiment])
}

// === Pricing extras ===

model Promotion {
  id              String   @id
  name            String
  type            String
  discountPercent Float    @default(0)
  discountAmount  Float    @default(0)
  appliesTo       Json     @default("[]")
  startsAt        DateTime
  endsAt          DateTime
  usageLimit      Int?
  usageCount      Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  createdBy       String?

  @@index([active])
  @@index([startsAt, endsAt])
}

model DiscountApplied {
  id          String   @id
  orderId     String
  promotionId String?
  type        String
  amount      Float    @default(0)
  description String?
  appliedAt   DateTime
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([promotionId])
}

model PriceRule {
  id          String   @id
  name        String
  type        String
  config      Json     @default("{}")
  priority    Int      @default(0)
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  createdAt   DateTime @default(now())

  @@index([active])
}

// === Shipping extras ===

model ShippingLabel {
  id                 String   @id
  shipmentId         String   @unique
  carrier            String
  carrierCode        String?
  trackingCode       String   @unique
  trackingUrl        String?
  shippingCost       Float    @default(0)
  estimatedDeliveryDate DateTime?
  generatedAt        DateTime
  createdAt          DateTime @default(now())
}

model TrackingEvent {
  id          String   @id @default(uuid())
  shipmentId  String
  trackingCode String
  status      String
  statusDetail String?
  location    String
  city        String?
  state       String?
  updatedAt   DateTime
  createdAt   DateTime @default(now())

  @@index([shipmentId])
  @@index([trackingCode])
  @@index([status])
}

// === Analytics extras ===

model AnomalyAlert {
  id              String   @id
  context         String
  metric          String
  expectedValue   Float    @default(0)
  actualValue     Float    @default(0)
  deviationPercent Float
  severity        String   @default("medium")
  detectedAt      DateTime
  acknowledged    Boolean  @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([context])
  @@index([severity])
  @@index([acknowledged])
}

model KPIMetric {
  id          String   @id
  name        String   @unique
  value       Float    @default(0)
  target      Float    @default(0)
  unit        String
  period      String   @default("daily")
  recordedAt  DateTime
  createdAt   DateTime @default(now())

  @@index([name, period])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @default("")
  group     String   @default("general")
  secure    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

model Document {
  id           String   @id @default(uuid())
  name         String
  type         String   @default("contrato")
  counterparty String?
  status       String   @default("Ativo")
  value        Float?
  period       String?
  signedBy     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model DocumentFile {
  id        String   @id @default(uuid())
  name      String
  size      String   @default("0 KB")
  type      String   @default("arquivo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

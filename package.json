{
  "name": "@athena/core",
  "version": "0.0.1",
  "private": true,
  "description": "ATHENA — Sistema Operacional de Inteligencia Empresarial para Transformacao Plastica",
  "engines": {
    "node": ">=22.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bootstrap/startup.js",
    "dev": "ts-node src/bootstrap/startup.ts",
    "watch": "tsc --build --watch",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "generate:asyncapi": "ts-node scripts/generate-asyncapi.ts",
    "generate:events": "ts-node scripts/generate-event-index.ts",
    "migrate": "npx prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "docker:up": "docker compose -f docker/development/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/development/docker-compose.yml down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-otlp-http": "^0.26.0",
    "@opentelemetry/instrumentation-fastify": "^0.56.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@prisma/client": "^7.8.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "graphql": "^16.14.2",
    "groq-sdk": "^1.3.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "mercurius": "^16.9.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}

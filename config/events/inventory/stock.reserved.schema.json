{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/inventory/v1/stock.reserved",
  "title": "StockReserved",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "inventory.v1.stock.reserved" },
    "payload": {
      "type": "object",
      "required": ["reservationId", "orderId", "items", "reservedAt"],
      "properties": {
        "reservationId": { "type": "string", "format": "uuid" },
        "orderId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "quantity", "warehouseId"],
            "properties": {
              "sku": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1 },
              "warehouseId": { "type": "string" },
              "location": { "type": "string" }
            }
          }
        },
        "reservedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

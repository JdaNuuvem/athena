{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/inventory/v1/stock.adjusted",
  "title": "StockAdjusted",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "inventory.v1.stock.adjusted" },
    "payload": {
      "type": "object",
      "required": ["adjustmentId", "warehouseId", "items", "reason", "adjustedAt"],
      "properties": {
        "adjustmentId": { "type": "string", "format": "uuid" },
        "warehouseId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "previousQuantity", "newQuantity", "difference"],
            "properties": {
              "sku": { "type": "string" },
              "previousQuantity": { "type": "integer" },
              "newQuantity": { "type": "integer" },
              "difference": { "type": "integer" },
              "location": { "type": "string" }
            }
          }
        },
        "reason": { "type": "string", "enum": ["cycle_count", "damage", "loss", "correction", "return", "transfer"] },
        "adjustedAt": { "type": "string", "format": "date-time" },
        "adjustedBy": { "type": "string" }
      }
    }
  }
}

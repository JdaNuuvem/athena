{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/inventory/v1/stock.shipped",
  "title": "StockShipped",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "inventory.v1.stock.shipped" },
    "payload": {
      "type": "object",
      "required": ["movementId", "orderId", "warehouseId", "items", "shippedAt"],
      "properties": {
        "movementId": { "type": "string", "format": "uuid" },
        "orderId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "quantity"],
            "properties": {
              "sku": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1 },
              "batchLot": { "type": "string" },
              "location": { "type": "string" }
            }
          }
        },
        "shippedAt": { "type": "string", "format": "date-time" },
        "carrierId": { "type": "string" }
      }
    }
  }
}

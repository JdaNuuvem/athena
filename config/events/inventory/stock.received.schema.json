{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/inventory/v1/stock.received",
  "title": "StockReceived",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "inventory.v1.stock.received" },
    "payload": {
      "type": "object",
      "required": ["movementId", "warehouseId", "items", "receivedAt"],
      "properties": {
        "movementId": { "type": "string", "format": "uuid" },
        "warehouseId": { "type": "string" },
        "warehouseName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "quantity", "location"],
            "properties": {
              "sku": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1 },
              "batchLot": { "type": "string" },
              "location": { "type": "string" },
              "unitCost": { "type": "number" }
            }
          }
        },
        "receivedAt": { "type": "string", "format": "date-time" },
        "supplierId": { "type": "string" },
        "purchaseOrderId": { "type": "string" },
        "productionBatchId": { "type": "string" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/product-engineering/v1/revision.approved",
  "title": "RevisionApproved",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "product-engineering.v1.revision.approved" },
    "payload": {
      "type": "object",
      "required": ["revisionId", "productId", "revisionNumber", "approvedBy"],
      "properties": {
        "revisionId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "revisionNumber": { "type": "string" },
        "changesDescription": { "type": "string" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "cadFileHash": { "type": "string" }
      }
    }
  }
}

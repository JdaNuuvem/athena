{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/product-engineering/v1/product.archived",
  "title": "ProductArchived",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "product-engineering.v1.product.archived" },
    "payload": {
      "type": "object",
      "required": ["productId", "reason"],
      "properties": {
        "productId": { "type": "string", "format": "uuid" },
        "sku": { "type": "string" },
        "reason": { "type": "string" },
        "archivedBy": { "type": "string" },
        "previousStatus": { "type": "string", "enum": ["draft", "active", "deprecated"] }
      }
    }
  }
}

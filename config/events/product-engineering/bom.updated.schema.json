{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/product-engineering/v1/bom.updated",
  "title": "BOMUpdated",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "product-engineering.v1.bom.updated" },
    "payload": {
      "type": "object",
      "required": ["bomId", "productId", "components"],
      "properties": {
        "bomId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "revisionNumber": { "type": "string" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["componentId", "name", "quantity"],
            "properties": {
              "componentId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1 },
              "materialSpec": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "totalComponents": { "type": "integer" }
      }
    }
  }
}

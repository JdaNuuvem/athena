{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/customer/v1/customer.registered",
  "title": "CustomerRegistered",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "customer.v1.customer.registered" },
    "payload": {
      "type": "object",
      "required": ["customerId", "name", "email", "registeredAt"],
      "properties": {
        "customerId": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "document": { "type": "string" },
        "channelOrigin": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu", "retail", "telegram", "website", "manual"] },
        "registeredAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

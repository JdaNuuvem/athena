{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/customer/v1/tier.changed",
  "title": "TierChanged",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "customer.v1.tier.changed" },
    "payload": {
      "type": "object",
      "required": ["customerId", "previousTier", "newTier", "changedAt"],
      "properties": {
        "customerId": { "type": "string" },
        "previousTier": { "type": "string", "enum": ["bronze", "silver", "gold", "diamond"] },
        "newTier": { "type": "string", "enum": ["bronze", "silver", "gold", "diamond"] },
        "reason": { "type": "string" },
        "lifetimeValue": { "type": "number" },
        "totalOrders": { "type": "integer", "minimum": 0 },
        "changedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/customer/v1/churn.risk.detected",
  "title": "ChurnRiskDetected",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "customer.v1.churn.risk.detected" },
    "payload": {
      "type": "object",
      "required": ["customerId", "riskScore", "detectedAt"],
      "properties": {
        "customerId": { "type": "string" },
        "riskScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "factors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "factor": { "type": "string" },
              "contribution": { "type": "number" }
            }
          }
        },
        "daysSinceLastOrder": { "type": "number" },
        "detectedAt": { "type": "string", "format": "date-time" },
        "recommendedAction": { "type": "string" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/mold-making/v1/mold.designed",
  "title": "MoldDesigned",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "mold-making.v1.mold.designed" },
    "payload": {
      "type": "object",
      "required": ["moldId", "productId", "cavityCount", "steelType", "designedAt"],
      "properties": {
        "moldId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "moldCode": { "type": "string" },
        "cavityCount": { "type": "integer", "minimum": 1 },
        "steelType": { "type": "string" },
        "coolingConfig": { "type": "string" },
        "ejectorType": { "type": "string" },
        "estimatedCycleLife": { "type": "integer" },
        "estimatedCycleTimeSec": { "type": "number" },
        "cadFileHash": { "type": "string" },
        "designedAt": { "type": "string", "format": "date-time" },
        "designedBy": { "type": "string" }
      }
    }
  }
}

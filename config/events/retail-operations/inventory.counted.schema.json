{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/retail-operations/v1/inventory.counted",
  "title": "InventoryCounted",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "retail-operations.v1.inventory.counted" },
    "payload": {
      "type": "object",
      "required": ["countId", "storeId", "countedAt"],
      "properties": {
        "countId": { "type": "string", "format": "uuid" },
        "storeId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "systemQuantity", "physicalQuantity", "difference"],
            "properties": {
              "sku": { "type": "string" },
              "systemQuantity": { "type": "integer" },
              "physicalQuantity": { "type": "integer" },
              "difference": { "type": "integer" }
            }
          }
        },
        "countedAt": { "type": "string", "format": "date-time" },
        "countedBy": { "type": "string" },
        "status": { "type": "string", "enum": ["in_progress", "completed", "requires_recount"] }
      }
    }
  }
}

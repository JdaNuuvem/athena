{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/telegram-commerce/v1/order.confirmed",
  "title": "OrderConfirmedViaChat",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "telegram-commerce.v1.order.confirmed" },
    "payload": {
      "type": "object",
      "required": ["chatOrderId", "telegramUserId", "chatId", "items", "totals", "confirmedAt"],
      "properties": {
        "chatOrderId": { "type": "string" },
        "telegramUserId": { "type": "string" },
        "chatId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "quantity", "unitPrice"],
            "properties": {
              "sku": { "type": "string" },
              "quantity": { "type": "integer" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "shippingAddress": {
          "type": "object",
          "required": ["recipientName", "city", "state", "zipCode"],
          "properties": {
            "recipientName": { "type": "string" },
            "street": { "type": "string" },
            "number": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zipCode": { "type": "string" }
          }
        },
        "totals": {
          "type": "object",
          "required": ["subtotal", "grandTotal", "currency"],
          "properties": {
            "subtotal": { "type": "number" },
            "shipping": { "type": "number" },
            "discount": { "type": "number" },
            "grandTotal": { "type": "number" },
            "currency": { "type": "string", "default": "BRL" }
          }
        },
        "confirmedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/catalog/v1/media.added",
  "title": "MediaAdded",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "catalog.v1.media.added" },
    "payload": {
      "type": "object",
      "required": ["mediaId", "productId", "type", "url"],
      "properties": {
        "mediaId": { "type": "string", "format": "uuid" },
        "productId": { "type": "string", "format": "uuid" },
        "type": { "type": "string", "enum": ["image", "video", "manual", "spec_sheet", "certificate"] },
        "url": { "type": "string", "format": "uri" },
        "filename": { "type": "string" },
        "sortOrder": { "type": "integer" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isMain": { "type": "boolean" }
      }
    }
  }
}

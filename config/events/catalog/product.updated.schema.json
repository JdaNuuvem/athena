{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/catalog/v1/product.updated",
  "title": "ProductUpdated",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "catalog.v1.product.updated" },
    "payload": {
      "type": "object",
      "required": ["productId", "changedFields"],
      "properties": {
        "productId": { "type": "string", "format": "uuid" },
        "sku": { "type": "string" },
        "changedFields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "newValues": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "price": { "type": "number" },
            "categoryId": { "type": "string" },
            "status": { "type": "string" }
          }
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/catalog/v1/product.published",
  "title": "ProductPublished",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "catalog.v1.product.published" },
    "payload": {
      "type": "object",
      "required": ["productId", "title", "status"],
      "properties": {
        "productId": { "type": "string", "format": "uuid" },
        "sku": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "bulletPoints": { "type": "array", "items": { "type": "string" } },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "gtin": { "type": "string" },
        "ncm": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "seoMetadata": {
          "type": "object",
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "keywords": { "type": "array", "items": { "type": "string" } }
          }
        },
        "publishedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/order-management/v1/order.delivered",
  "title": "OrderDelivered",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "order-management.v1.order.delivered" },
    "payload": {
      "type": "object",
      "required": ["orderId", "deliveredAt"],
      "properties": {
        "orderId": { "type": "string" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "receivedBy": { "type": "string" },
        "deliveryNotes": { "type": "string" },
        "onTime": { "type": "boolean" },
        "deliveryAttempts": { "type": "integer" }
      }
    }
  }
}

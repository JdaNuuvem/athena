{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/order-management/v1/order.confirmed",
  "title": "OrderConfirmed",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "order-management.v1.order.confirmed" },
    "payload": {
      "type": "object",
      "required": ["orderId", "confirmedAt"],
      "properties": {
        "orderId": { "type": "string" },
        "fraudCheckResult": { "type": "string", "enum": ["approved", "manual_review", "rejected"] },
        "confirmedAt": { "type": "string", "format": "date-time" },
        "confirmedBy": { "type": "string" },
        "estimatedShipDate": { "type": "string", "format": "date" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/order-management/v1/order.placed",
  "title": "OrderPlaced",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "order-management.v1.order.placed" },
    "payload": {
      "type": "object",
      "required": ["orderId", "channel", "items", "customerId", "totals"],
      "properties": {
        "orderId": { "type": "string" },
        "channel": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu", "retail", "telegram", "manual"] },
        "sourceId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sku", "quantity", "unitPrice", "total"],
            "properties": {
              "sku": { "type": "string" },
              "quantity": { "type": "integer" },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "customerId": { "type": "string" },
        "shippingAddress": {
          "type": "object",
          "required": ["recipientName", "city", "state", "zipCode"],
          "properties": {
            "recipientName": { "type": "string" },
            "street": { "type": "string" },
            "number": { "type": "string" },
            "complement": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zipCode": { "type": "string" }
          }
        },
        "totals": {
          "type": "object",
          "required": ["subtotal", "grandTotal", "currency"],
          "properties": {
            "subtotal": { "type": "number" },
            "shipping": { "type": "number" },
            "discount": { "type": "number" },
            "grandTotal": { "type": "number" },
            "currency": { "type": "string", "default": "BRL" }
          }
        },
        "paymentMethod": { "type": "string" },
        "installments": { "type": "integer", "minimum": 1 }
      }
    }
  }
}

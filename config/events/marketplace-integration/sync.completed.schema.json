{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/marketplace-integration/v1/sync.completed",
  "title": "SyncCompleted",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "marketplace-integration.v1.sync.completed" },
    "payload": {
      "type": "object",
      "required": ["syncId", "channel", "syncType", "completedAt"],
      "properties": {
        "syncId": { "type": "string", "format": "uuid" },
        "channel": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu"] },
        "syncType": { "type": "string", "enum": ["full", "incremental", "event_driven"] },
        "listingsSynced": { "type": "integer", "minimum": 0 },
        "listingsFailed": { "type": "integer", "minimum": 0 },
        "errors": { "type": "array", "items": { "type": "string" } },
        "durationSeconds": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

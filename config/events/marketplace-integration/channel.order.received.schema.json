{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/marketplace-integration/v1/channel.order.received",
  "title": "ChannelOrderReceived",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "marketplace-integration.v1.channel.order.received" },
    "payload": {
      "type": "object",
      "required": ["channelOrderId", "channel", "items", "customer", "totals", "receivedAt"],
      "properties": {
        "channelOrderId": { "type": "string" },
        "channel": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu"] },
        "channelAccountId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["channelSku", "quantity", "unitPrice"],
            "properties": {
              "channelSku": { "type": "string" },
              "internalSku": { "type": "string" },
              "quantity": { "type": "integer", "minimum": 1 },
              "unitPrice": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "customer": {
          "type": "object",
          "required": ["name", "shippingAddress"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "shippingAddress": {
              "type": "object",
              "required": ["city", "state", "zipCode"],
              "properties": {
                "recipientName": { "type": "string" },
                "street": { "type": "string" },
                "number": { "type": "string" },
                "neighborhood": { "type": "string" },
                "city": { "type": "string" },
                "state": { "type": "string" },
                "zipCode": { "type": "string" }
              }
            }
          }
        },
        "totals": {
          "type": "object",
          "required": ["grandTotal", "currency"],
          "properties": {
            "subtotal": { "type": "number" },
            "shipping": { "type": "number" },
            "discount": { "type": "number" },
            "grandTotal": { "type": "number" },
            "currency": { "type": "string", "default": "BRL" }
          }
        },
        "receivedAt": { "type": "string", "format": "date-time" },
        "estimatedShipDeadline": { "type": "string", "format": "date" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/marketplace-integration/v1/channel.account.health",
  "title": "ChannelAccountHealth",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "marketplace-integration.v1.channel.account.health" },
    "payload": {
      "type": "object",
      "required": ["channelAccountId", "channel", "checkedAt"],
      "properties": {
        "channelAccountId": { "type": "string" },
        "channel": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu"] },
        "reputationLevel": { "type": "string" },
        "reputationColor": { "type": "string", "enum": ["green", "yellow", "orange", "red"] },
        "cancellationRate": { "type": "number" },
        "delayRate": { "type": "number" },
        "responseTimeMinutes": { "type": "number" },
        "healthScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "checkedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

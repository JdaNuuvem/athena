{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/marketplace-integration/v1/listing.published",
  "title": "ListingPublished",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "marketplace-integration.v1.listing.published" },
    "payload": {
      "type": "object",
      "required": ["listingId", "channel", "productId", "channelSku", "publishedAt"],
      "properties": {
        "listingId": { "type": "string", "format": "uuid" },
        "channel": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu"] },
        "productId": { "type": "string", "format": "uuid" },
        "channelSku": { "type": "string" },
        "channelListingId": { "type": "string" },
        "channelUrl": { "type": "string", "format": "uri" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "price": { "type": "number", "minimum": 0 },
        "stockQuantity": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["active", "paused", "closed"] }
      }
    }
  }
}

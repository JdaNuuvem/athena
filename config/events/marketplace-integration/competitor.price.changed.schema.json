{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "athena://events/marketplace-integration/v1/competitor.price.changed",
  "title": "CompetitorPriceChanged",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "timestamp", "correlationId", "tenantId", "source", "payload", "metadata"],
  "properties": {
    "eventType": { "const": "marketplace-integration.v1.competitor.price.changed" },
    "payload": {
      "type": "object",
      "required": ["sku", "channel", "competitorId", "newPrice", "detectedAt"],
      "properties": {
        "sku": { "type": "string" },
        "channel": { "type": "string", "enum": ["mercadolivre", "shopee", "amazon", "magalu"] },
        "competitorId": { "type": "string" },
        "competitorName": { "type": "string" },
        "previousPrice": { "type": "number" },
        "newPrice": { "type": "number", "minimum": 0 },
        "ourPrice": { "type": "number" },
        "priceDifferencePercent": { "type": "number" },
        "detectedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": "./src",
    "paths": {
      "@shared/*": ["shared/*"],
      "@contexts/*": ["contexts/*"],
      "@agents/*": ["agents/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules", "dist", "tests",
    "src/contexts/analytics",
    "src/contexts/catalog/infrastructure/persistence/prisma-catalog-repo.ts",
    "src/contexts/customer/infrastructure/persistence/prisma-customer-repo.ts",
    "src/contexts/inventory/domain/entities/stock-item.ts",
    "src/contexts/inventory/domain/repositories",
    "src/contexts/inventory/infrastructure/infrastructure",
    "src/contexts/inventory/infrastructure/persistence/prisma-stock-repo.ts",
    "src/contexts/inventory/application/use-cases",
    "src/contexts/inventory/application/queries",
    "src/contexts/order-management/domain/entities/order.ts",
    "src/contexts/order-management/domain/repositories",
    "src/contexts/order-management/infrastructure/infrastructure",
    "src/contexts/order-management/infrastructure/persistence/prisma-order-repo.ts",
    "src/contexts/order-management/application/use-cases",
    "src/contexts/order-management/application/event-handlers/on-",
    "src/contexts/product-engineering/domain/entities/product.ts",
    "src/contexts/product-engineering/domain/repositories",
    "src/contexts/product-engineering/domain/value-objects",
    "src/contexts/product-engineering/infrastructure/infrastructure",
    "src/contexts/product-engineering/infrastructure/persistence/prisma-bom-repo.ts",
    "src/contexts/product-engineering/application/use-cases",
    "src/contexts/product-engineering/application/queries",
    "src/contexts/shipping",
    "src/contexts/pricing",
    "src/contexts/marketplace-integration",
    "src/contexts/retail-operations",
    "src/agents/instances/observers/product-design-assistant.ts",
    "src/agents/tasks",
    "src/api/rest/dashboard-routes.ts",
    "src/api/auth",
    "src/graphql",
    "src/config",
    "src/main.ts",
    "src/**/in-memory-*.ts",
    "src/**/on-channel-order*.ts",
    "src/**/on-retail-sale*.ts",
    "src/**/on-stock-reserved*.ts",
    "src/**/on-stock-shipped*.ts",
    "src/**/on-telegram-order*.ts",
    "src/**/order-ingestion*.ts",
    "src/**/analytics-repo.ts",
    "src/**/analytics-consumer.ts",
    "src/**/product-vo.ts",
    "src/**/product-repository.ts"
  ]
}
